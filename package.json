{
  "name": "lms_express_api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "cross-env JWT_SECRET=test_secret vitest run --no-fileParallelism --maxWorkers 1",
    "test:watch": "cross-env JWT_SECRET=test_secret vitest --no-fileParallelism --maxWorkers 1",
    "test:ui": "cross-env JWT_SECRET=test_secret vitest --ui --no-fileParallelism --maxWorkers 1",
    "test:coverage": "cross-env JWT_SECRET=test_secret vitest run --coverage --no-fileParallelism --maxWorkers 1",
    "dev": "nodemon --watch src --ext ts --exec \"ts-node -T -r tsconfig-paths/register src/index.ts\"",
    "seed": "tsx prisma/seed.ts",
    "seed:posttest": "tsx prisma/seed-posttest.ts",
    "seed:final": "tsx prisma/finalseed.ts",
    "build": "prisma generate && node build.mjs",
    "start": "node dist/index.js",
    "db:generate": "prisma generate --schema=./prisma",
    "db:migrate": "prisma migrate dev"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
