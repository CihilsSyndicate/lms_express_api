// --- LEARNING CONTENT ---

model Modul {
    id                     String   @id @default(cuid())
    moduleName             String
    subtitle               String
    description            String   @db.Text
    targetTime             Int // dalam menit
    difficulty             String // e.g., 'Beginner', 'Advanced'
    isPaid                 Boolean  @default(false)
    modulPrice             Decimal?
    level                  String? // e.g., 'SD', 'SMP', 'SMA'
    class                  String?
    pretestPostTestEnabled Boolean  @default(true)
    hasStudyGroup          Boolean  @default(false)
    hasCertificate              Boolean  @default(false)
    isTestComputationalThinking Boolean  @default(false)
    moduleImgUrl                String?
    rangkumanAkhir         String?  @db.Text

    modulType ModulType @default(SISWA)

    tutorId String
    tutor   Tutor  @relation(fields: [tutorId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    topiks     Topik[]
    pretest    Pretest?  @relation(fields: [pretestId], references: [id], onDelete: SetNull, onUpdate: Cascade)
    pretestId  String?   @unique
    posttest   Posttest? @relation(fields: [posttestId], references: [id], onDelete: SetNull, onUpdate: Cascade)
    posttestId String?   @unique
    isDraft    Boolean   @default(true)

    progress               Progress[]
    certificates           Certificate[]
    knowledgeComponents    KnowledgeComponent[]
    unlockRules            ModuleUnlockRule[]
    answerLogs             StudentAnswerLog[]
    knowledgeStates        StudentKnowledgeState[]
    computationalThinkings ComputationalThinking[]
    ratings                Rating[]

    createdAt               DateTime                @default(now())
    updatedAt               DateTime                @updatedAt
    automaticAccessMateries AutomaticAccessMatery[]
}

model Topik {
    id                      String                  @id @default(cuid())
    nama                    String
    modulId                 String
    modul                   Modul                   @relation(fields: [modulId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    topikItems              TopikItem[]
    automaticAccessMateries AutomaticAccessMatery[]
    isComputationalThinking Boolean                 @default(false)
    rangkumanTopik          String?                 @db.Text

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    materis   Materi[]
    quizzes   Quiz[]
}

model TopikItem {
    id      String @id @default(cuid())
    topikId String
    topik   Topik  @relation(fields: [topikId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    itemId      String
    orderNumber Int

    itemType ItemType @default(MATERI)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([topikId, orderNumber])
}

model Materi {
    id       String  @id @default(cuid())
    tutorId  String
    tutor    Tutor   @relation(fields: [tutorId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    judul    String
    isVideo  Boolean @default(false)
    videoUrl String?
    article  String? @db.Text
    topikId  String
    topik    Topik   @relation(fields: [topikId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    createdAt               DateTime                @default(now())
    updatedAt               DateTime                @updatedAt
    automaticAccessMateries AutomaticAccessMatery[]
    progress_details        ProgressDetail[]
}

model Quiz {
    id                 String  @id @default(cuid())
    topikId            String
    topik              Topik   @relation(fields: [topikId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    quizType           QuizType @default(REGULER)
    quizImgQuestionUrl String?

    question String @db.Text

    correctAnswer String
    skor          Int    @default(10)

    quizAnswerOptions QuizAnswerOption[]
    quizSettings      QuizSetting[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model QuizAnswerOption {
    id     String @id @default(cuid())
    quizId String
    quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    option String

    createdAt DateTime @default(now())
}

model QuizSetting {
    id                             String  @id @default(cuid())
    quizId                         String
    quiz                           Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    timeLimit                      Int? // dalam detik
    allowMultipleAttempts          Boolean @default(false)
    isComputationalThinkingEnabled Boolean @default(false)
    minScoreTreshold               Int? // skor minimum untuk dianggap lulus
    standardScorePerQuestion       Int     @default(100)

    createdAt DateTime @default(now())
}

// --- ASSESSMENT SYSTEM ---
model Pretest {
    id               String        @id @default(cuid())
    pretestName      String
    modul            Modul?
    pretestQuestions SoalPretest[]

    createdAt               DateTime                @default(now())
    updatedAt               DateTime                @updatedAt
    pretestSettings         PretestSetting[]
    automaticAccessMateries AutomaticAccessMatery[]
}

model Posttest {
    id    String         @id @default(cuid())
    modul Modul?
    soals SoalPosttest[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    posttestSettings PosttestSetting[]
}

model PosttestSetting {
    id         String   @id @default(cuid())
    posttestId String
    posttest   Posttest @relation(fields: [posttestId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    duration   Int      // dalam menit — dikonversi ke detik di study-room
    createdAt  DateTime @default(now())
}

model SoalPretest {
    id                    String                    @id @default(cuid())
    pretestId             String
    pretest               Pretest                   @relation(fields: [pretestId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    pertanyaan            String                    @db.Text
    pretestQuestionImgUrl String?
    answerOptions         PretestAnswerOptions[]
    correctAnswer         String
    skor                  Int                       @default(10)
    ctGroupId             String?
    ctStory               String?                   @db.Text
    ctAspect              String?
    questionMaps          PretestQuestionSkillMap[]
    automaticAccessMatery AutomaticAccessMatery[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model PretestAnswerOptions {
    id              String      @id @default(cuid())
    soalPretestId   String
    pretestQuestion SoalPretest @relation(fields: [soalPretestId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    option          String

    createdAt DateTime @default(now())
}

model PretestSetting {
    id                  String  @id @default(cuid())
    pretestId           String
    pretest             Pretest @relation(fields: [pretestId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    duration            Int // dalam detik
    countShownQuestions Int

    createdAt DateTime @default(now())
}

model AutomaticAccessMatery {
    id        String   @id @default(cuid())
    pretestId String?
    pretest   Pretest? @relation(fields: [pretestId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    materiId  String
    materi    Materi   @relation(fields: [materiId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    minScore       Int     @default(0)
    selectedTopics Topik[]

    createdAt     DateTime     @default(now())
    modul         Modul?       @relation(fields: [modulId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    modulId       String?
    soalPretest   SoalPretest? @relation(fields: [soalPretestId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    soalPretestId String?
}

model SoalPosttest {
    id            String   @id @default(cuid())
    posttestId    String
    posttest      Posttest @relation(fields: [posttestId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    question      String   @db.Text
    pilihan       Json
    correctAnswer String
    skor          Int      @default(10)
    ctGroupId     String?
    ctStory       String?  @db.Text
    ctAspect      String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

// Computational Thinking
model ComputationalThinking {
    id        String  @id @default(cuid())
    modulId   String
    modul     Modul   @relation(fields: [modulId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    aspek     String // e.g., 'Decomposition', 'Pattern Recognition'
    deskripsi String? @db.Text

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

// Certificate
model Certificate {
    id             String   @id @default(cuid())
    siswaId        String
    siswa          Siswa    @relation(fields: [siswaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    modulId        String
    modul          Modul    @relation(fields: [modulId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    kode_sertif    String   @unique
    issued_at      DateTime @default(now())
    certificateUrl String

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([siswaId, modulId])
    @@index([siswaId])
}

// --- BAYESIAN KNOWLEDGE TRACING ---
model KnowledgeComponent {
    id        String   @id @default(cuid())
    modulId   String
    modul     Modul    @relation(fields: [modulId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    code      String // e.g., "algebra_basics"
    nama      String
    deskripsi String?  @db.Text
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    questionMaps    PretestQuestionSkillMap[]
    answerLogs      StudentAnswerLog[]
    knowledgeStates StudentKnowledgeState[]
    unlockRules     ModuleUnlockRule[]

    @@map("knowledge_component")
}

model PretestQuestionSkillMap {
    id                   String             @id @default(cuid())
    pretestQuestionId    String
    soalPretest          SoalPretest        @relation(fields: [pretestQuestionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    knowledgeComponentId String
    knowledgeComponent   KnowledgeComponent @relation(fields: [knowledgeComponentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    weight               Float              @default(1.0) // bobot skill di soal

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([pretestQuestionId, knowledgeComponentId])
    @@map("pretest_question_skill_map")
}

model Rating {
    id       String  @id @default(cuid())
    rating   Int
    komentar String? @db.Text

    siswaId String
    siswa   Siswa  @relation(fields: [siswaId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    modul   Modul?  @relation(fields: [modulId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    modulId String?
}

enum ModulType {
    SISWA
    UMUM
}

enum ItemType {
    MATERI
    QUIZ
    RANGKUMAN_TOPIK
}

enum QuizType {
    REGULER
    COMPUTATIONAL_THINKING
}
