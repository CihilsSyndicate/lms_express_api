model Tutor {
    id             String        @id @default(cuid())
    fullName       String
    email          String        @unique
    password       String
    gender         String
    pekerjaan      String
    whatsappNumber String
    lastEducation  String
    institution    String
    biografi       String?
    prodi          String
    cvPathUrl      String
    profileImg     String?
    role           String        @default("tutor")
    moduls         Modul[]
    materis        Materi[]
    googleId       String?       @unique
    signatures     Signature[]
    socialMedias   SocialMedia[]

    isActive Boolean @default(true)
}

model Signature {
    id      String @id @default(cuid())
    tutorId String
    tutor   Tutor  @relation(fields: [tutorId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    fileUrl String
}

model SocialMedia {
    id       String @id @default(cuid())
    tutorId  String
    tutor    Tutor  @relation(fields: [tutorId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    platform String
    url      String

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
