// Konfigurasi standar
generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Notification {
  id      String @id @default(uuid())
  userId  String
  title   String
  message String

  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
